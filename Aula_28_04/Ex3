import java.util.ArrayList;
import java.util.List;

interface Tributavel {
    double calcularImposto();
}

class DescontoInvalidoException extends RuntimeException {
    public DescontoInvalidoException(String mensagem) {
        super(mensagem);
    }
}

abstract class Produto {
    protected String descricao;
    protected double valorOriginal;

    public Produto(String descricao, double valorOriginal) {
        this.descricao = descricao;
        this.valorOriginal = valorOriginal;
    }

    public String getDescricao() {
        return descricao;
    }

    public double getValorOriginal() {
        return valorOriginal;
    }

    public void aplicarDesconto(double porcentagem) {
        if (porcentagem < 0 || porcentagem > 50) {
            throw new DescontoInvalidoException(
                "Desconto inválido: " + porcentagem + "%. Permitido entre 0% e 50%."
            );
        }
        this.valorOriginal -= valorOriginal * porcentagem / 100;
    }
}

class Eletronico extends Produto implements Tributavel {
    public Eletronico(String descricao, double valorOriginal) {
        super(descricao, valorOriginal);
    }

    @Override
    public double calcularImposto() {
        return valorOriginal * 0.15;
    }

    @Override
    public void aplicarDesconto(double porcentagem) {
        System.out.println("[Eletrônico] aplicando " + porcentagem + "% em " + descricao);
        super.aplicarDesconto(porcentagem);
    }
}

class Vestuario extends Produto implements Tributavel {
    public Vestuario(String descricao, double valorOriginal) {
        super(descricao, valorOriginal);
    }

    @Override
    public double calcularImposto() {
        return valorOriginal * 0.05;
    }

    @Override
    public void aplicarDesconto(double porcentagem) {
        System.out.println("[Vestuário] aplicando " + porcentagem + "% em " + descricao);
        super.aplicarDesconto(porcentagem);
    }
}

class Alimento extends Produto {
    public Alimento(String descricao, double valorOriginal) {
        super(descricao, valorOriginal);
    }

    @Override
    public void aplicarDesconto(double porcentagem) {
        System.out.println("[Alimento] aplicando " + porcentagem + "% em " + descricao);
        super.aplicarDesconto(porcentagem);
    }
}

public class Exercicio3 {
    public static void main(String[] args) {
        List<Produto> produtos = new ArrayList<>();

        produtos.add(new Eletronico("Notebook Dell", 3500.00));
        produtos.add(new Vestuario("Camiseta básica", 80.00));
        produtos.add(new Alimento("Arroz 5kg", 30.00));
        produtos.add(new Eletronico("Smartphone Samsung", 2500.00));
        produtos.add(new Vestuario("Tênis esportivo", 250.00));
        produtos.add(new Alimento("Feijão 1kg", 9.50));

        System.out.println("=== Aplicando descontos ===");
        try {
            produtos.get(0).aplicarDesconto(10);
            produtos.get(2).aplicarDesconto(5);
        } catch (DescontoInvalidoException e) {
            System.out.println("Erro: " + e.getMessage());
        }

        System.out.println("\n=== Teste de desconto inválido ===");
        try {
            produtos.get(1).aplicarDesconto(60);
        } catch (DescontoInvalidoException e) {
            System.out.println("Capturado -> " + e.getMessage());
        }

        try {
            produtos.get(3).aplicarDesconto(-5);
        } catch (DescontoInvalidoException e) {
            System.out.println("Capturado -> " + e.getMessage());
        }

        System.out.println("\n=== Cálculo de impostos ===");
        double totalImpostos = 0;
        for (Produto p : produtos) {
            if (p instanceof Tributavel) {
                Tributavel t = (Tributavel) p;
                double imposto = t.calcularImposto();
                System.out.printf("%-25s | Valor: R$ %7.2f | Imposto: R$ %6.2f%n",
                    p.getDescricao(), p.getValorOriginal(), imposto);
                totalImpostos += imposto;
            } else {
                System.out.printf("%-25s | Valor: R$ %7.2f | Isento%n",
                    p.getDescricao(), p.getValorOriginal());
            }
        }
        System.out.printf("%nTotal de impostos a pagar: R$ %.2f%n", totalImpostos);
    }
}